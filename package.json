{
	"name": "ditherette",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "wrangler types --check && vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check": "node -e \"import('node:fs').then(fs=>{fs.rmSync('.svelte-kit/output',{recursive:true,force:true});fs.rmSync('.svelte-kit/cloudflare',{recursive:true,force:true});})\" && wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:e2e": "playwright install && playwright test",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:unit": "vitest",
		"gen": "wrangler types",
		"wasm:build": "pnpm dlx wasm-pack build crates/ditherette-wasm --target web",
		"wasm:test": "pnpm dlx wasm-pack test --node crates/ditherette-wasm",
		"wasm:test:browser": "pnpm dlx wasm-pack test --headless --chrome crates/ditherette-wasm",
		"bench:rust-resize": "node scripts/benchmark-rust-resize.mjs",
		"bench:rust-bilinear": "node scripts/benchmark-rust-resize.mjs --kernel bilinear",
		"bench:rust-filters": "node scripts/benchmark-rust-resize.mjs --kernel filters",
		"bench:nearest": "node scripts/benchmark-rust-resize.mjs --kernel filters --filter nearest",
		"bench:nearest:aa": "node scripts/benchmark-rust-resize.mjs --kernel filters --filter nearest_aa",
		"bench:bilinear": "node scripts/benchmark-rust-resize.mjs --kernel filters --filter bilinear",
		"bench:trilinear": "node scripts/benchmark-rust-resize.mjs --kernel filters --filter trilinear",
		"bench:bicubic": "node scripts/benchmark-rust-resize.mjs --kernel filters --filter bicubic",
		"bench:lanczos2": "node scripts/benchmark-rust-resize.mjs --kernel filters --filter lanczos2",
		"bench:lanczos2-scale-aware": "node scripts/benchmark-rust-resize.mjs --kernel filters --filter lanczos2_scale_aware",
		"bench:lanczos3": "node scripts/benchmark-rust-resize.mjs --kernel filters --filter lanczos3",
		"bench:lanczos3-scale-aware": "node scripts/benchmark-rust-resize.mjs --kernel filters --filter lanczos3_scale_aware",
		"bench:area": "node scripts/benchmark-rust-resize.mjs --kernel filters --filter area",
		"bench:box": "node scripts/benchmark-rust-resize.mjs --kernel filters --filter box",
		"bench:antialias": "node scripts/benchmark-rust-resize.mjs --kernel filters --filter antialias",
		"bench:wasm-resize": "pnpm wasm:build && node scripts/benchmark-wasm-resize.mjs"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/geist": "^5.2.8",
		"@internationalized/date": "^3.12.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-cloudflare": "latest",
		"@sveltejs/kit": "latest",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/table-core": "^8.21.3",
		"@types/katex": "^0.16.8",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.3",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"embla-carousel-svelte": "^8.6.0",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"formsnap": "^2.0.1",
		"globals": "^17.4.0",
		"layerchart": "2.0.0-next.48",
		"mode-watcher": "^1.1.0",
		"paneforge": "^1.0.2",
		"phosphor-svelte": "^3.1.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"svelte-sonner": "^1.1.1",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vaul-svelte": "1.0.0-next.7",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"vitest-browser-svelte": "^2.1.0",
		"wrangler": "^4.81.0"
	},
	"dependencies": {
		"@nanostores/persistent": "^1.3.4",
		"effect": "4.0.0-beta.62",
		"katex": "^0.16.45",
		"nanostores": "^1.3.0"
	}
}
